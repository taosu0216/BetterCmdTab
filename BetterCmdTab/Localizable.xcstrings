    "Rounding of the panel's corners. Automatic follows the panel size.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Rundung der Ecken des Bedienfelds. „Automatisch“ richtet sich nach der Größe des Bedienfelds."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Redondeo de las esquinas del panel. «Automático» se ajusta al tamaño del panel."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrondi des coins du panneau. Le mode automatique suit la taille du panneau."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaokrąglenie narożników panelu. Automatyczny dopasowuje się do rozmiaru panelu."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "面板圆角大小。自动模式会跟随面板尺寸。"
          }
        }
      }
    },
    "Running apps with no open windows.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Laufende Apps ohne geöffnete Fenster."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apps en ejecución sin ventanas abiertas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apps en cours d’exécution sans fenêtre ouverte."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uruchomione aplikacje bez otwartych okien."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有打开窗口的运行中应用。"
          }
        }
      }
    },
    "Save all your settings to a file you can back up or move to another Mac.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sichert alle deine Einstellungen in einer Datei, die du als Backup verwenden oder auf einen anderen Mac übertragen kannst."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda todos tus ajustes en un archivo que puedes respaldar o trasladar a otro Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistre tous vos réglages dans un fichier que vous pouvez sauvegarder ou transférer sur un autre Mac."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapisz wszystkie ustawienia do pliku, który możesz zarchiwizować lub przenieść na innego Maca."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将所有设置保存到文件，方便备份或迁移到另一台 Mac。"
          }
        }
      }
    },
    "Scoped shortcut %lld": {
