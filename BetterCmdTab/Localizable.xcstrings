    "Picking an app on another Space or in full screen jumps there instantly, with no slide animation. Applies to keyboard switching too." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beim Auswählen einer App auf einem anderen Space oder im Vollbild springt die Ansicht sofort dorthin, ohne Schiebeanimation. Gilt auch für das Wechseln per Tastatur."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al seleccionar una app en otro espacio o en pantalla completa, salta allí al instante, sin animación de desplazamiento. También se aplica al cambio con el teclado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sélectionner une app sur un autre espace ou en plein écran y bascule instantanément, sans animation de glissement. S’applique aussi au changement au clavier."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wybranie aplikacji na innym biurku lub na pełnym ekranie powoduje natychmiastowy przeskok, bez animacji przesuwania. Dotyczy też przełączania klawiaturą."
          }
        }
      }
    },
