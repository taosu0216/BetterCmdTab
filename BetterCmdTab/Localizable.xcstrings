    "Choose an app to set switcher rules for.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle eine App, für die du Umschalter-Regeln festlegen möchtest."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige una app para establecer sus reglas del selector."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez une app pour définir ses règles de sélecteur."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz aplikację, dla której chcesz ustawić reguły przełącznika."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择要设置切换器规则的应用。"
          }
        }
      }
    },
    "Choose the app this shortcut focuses.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle die App, die dieser Kurzbefehl aktiviert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige la app que enfoca este atajo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez l’app que ce raccourci active."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz aplikację, którą ten skrót aktywuje."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择这个快捷键要聚焦的应用。"
          }
        }
      }
    },
    "Choose which apps appear in the switcher, and let some apps keep ⌘Tab for themselves.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle, welche Apps im Umschalter erscheinen, und lass einige Apps ⌘Tab für sich behalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige qué apps aparecen en el selector y permite que algunas apps conserven ⌘Tab para sí mismas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez les apps qui apparaissent dans le sélecteur, et laissez certaines apps conserver ⌘Tab pour elles-mêmes."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz, które aplikacje pojawiają się w przełączniku, i pozwól niektórym aplikacjom zachować ⌘Tab dla siebie."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择哪些应用显示在切换器中，并允许部分应用保留自己的 ⌘Tab。"
          }
        }
      }
    },
    "Choose which monitor the switcher opens on when you have more than one display.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lege fest, auf welchem Bildschirm sich der Umschalter öffnet, wenn du mehrere Bildschirme verwendest."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige en qué pantalla se abre el selector cuando tienes más de una pantalla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez sur quel écran le sélecteur s’ouvre lorsque vous avez plusieurs écrans."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz, na którym ekranie ma się otwierać przełącznik, gdy masz więcej niż jeden ekran."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "有多个显示器时，选择切换器在哪个显示器上打开。"
          }
        }
      }
    },
