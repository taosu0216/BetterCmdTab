    "Most recent keeps the classic ⌘Tab order; Most recent (windows) interleaves windows from all apps by last focus; the others stay put as you switch.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Zuletzt verwendet“ behält die klassische ⌘Tab-Reihenfolge bei; „Zuletzt verwendet (Fenster)“ reiht Fenster aller Apps nach dem letzten Fokus ein; die anderen bleiben beim Wechseln an Ort und Stelle."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«Más reciente» mantiene el orden clásico de ⌘Tab; «Más reciente (ventanas)» intercala las ventanas de todas las apps según el último uso; las demás permanecen en su sitio al cambiar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Récemment utilisé conserve l’ordre classique de ⌘Tab ; Récemment utilisé (fenêtres) intercale les fenêtres de toutes les apps selon leur dernière utilisation ; les autres restent en place lorsque vous changez."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ostatnio używane zachowuje klasyczną kolejność ⌘Tab; Ostatnio używane (okna) przeplata okna wszystkich aplikacji według ostatniego użycia; pozostałe pozostają na miejscu podczas przełączania."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“最近使用”保持经典 ⌘Tab 顺序；“最近使用（窗口）”按最后聚焦时间混排所有应用的窗口；其它排序在切换时保持固定。"
          }
        }
      }
    },
