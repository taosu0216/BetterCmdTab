    "Hide all windows": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Fenster ausblenden"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ocultar todas las ventanas"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Masquer toutes les fenêtres"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ukryj wszystkie okna"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐藏所有窗口"
          }
        }
      }
    },
    "Hide all windows hides every app, Finder included. Pick apps to keep visible.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Alle Fenster ausblenden“ blendet jede App aus, auch den Finder. Wähle Apps, die sichtbar bleiben."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«Ocultar todas las ventanas» oculta todas las apps, incluido el Finder. Elige apps que permanezcan visibles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« Masquer toutes les fenêtres » masque toutes les apps, Finder compris. Choisissez les apps à garder visibles."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "„Ukryj wszystkie okna” ukrywa każdą aplikację, łącznie z Finderem. Wybierz aplikacje, które mają pozostać widoczne."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐藏所有窗口会隐藏所有应用，包括 Finder。请选择要保持可见的应用。"
          }
        }
      }
    },
    "Hide app": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "App ausblenden"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ocultar app"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Masquer l’app"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ukryj aplikację"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐藏应用"
          }
        }
      }
    },
    "Hide every app to reveal the desktop. Works system-wide.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Apps ausblenden, um den Schreibtisch anzuzeigen. Funktioniert systemweit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Oculta todas las apps para mostrar el escritorio. Funciona en todo el sistema."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Masquer toutes les apps pour afficher le bureau. Fonctionne sur tout le système."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ukryj wszystkie aplikacje, aby pokazać pulpit. Działa w całym systemie."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐藏所有应用以显示桌面。全系统生效。"
          }
        }
      }
    },
    "Hide menu bar icon": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Menüleistensymbol ausblenden"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ocultar icono de la barra de menús"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Masquer l’icône de la barre des menus"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ukryj ikonę paska menu"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐藏菜单栏图标"
          }
        }
      }
    },
    "Hide the ⌘ icon. Reopen this window from Spotlight.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Blendet das ⌘-Symbol aus. Öffne dieses Fenster über Spotlight erneut."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Oculta el icono ⌘. Vuelve a abrir esta ventana desde Spotlight."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Masque l’icône ⌘. Rouvrez cette fenêtre depuis Spotlight."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ukryj ikonę ⌘. Otwórz to okno ponownie z poziomu Spotlight."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐藏 ⌘ 图标。可从 Spotlight 重新打开此窗口。"
          }
        }
      }
    },
    "Hide the app name in every layout; identify apps by their icon.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Blendet den App-Namen in allen Layouts aus; Apps werden am Symbol erkannt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Oculta el nombre de la aplicación en todas las disposiciones; identifica las apps por su icono."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Masque le nom de l’application dans toutes les dispositions ; identifiez les apps par leur icône."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ukrywa nazwę aplikacji we wszystkich układach; rozpoznawaj aplikacje po ikonie."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在所有布局中隐藏应用名称；通过图标识别应用。"
          }
        }
      }
    },
    "Hide the switcher from screen recordings and shared screens (Zoom, Meet, Teams). Needs macOS 14.6 or later.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Blendet den Umschalter bei Bildschirmaufnahmen und freigegebenen Bildschirmen aus (Zoom, Meet, Teams). Erfordert macOS 14.6 oder neuer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Oculta el selector en las grabaciones de pantalla y las pantallas compartidas (Zoom, Meet, Teams). Requiere macOS 14.6 o posterior."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Masque le sélecteur dans les enregistrements d’écran et les écrans partagés (Zoom, Meet, Teams). Nécessite macOS 14.6 ou ultérieur."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ukryj przełącznik przed nagraniami ekranu i udostępnianymi ekranami (Zoom, Meet, Teams). Wymaga systemu macOS 14.6 lub nowszego."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在屏幕录制和共享屏幕中隐藏切换器（Zoom、Meet、Teams）。需要 macOS 14.6 或更高版本。"
          }
        }
      }
    },
    "Hold ⌘": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "⌘ halten"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantener ⌘"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintenir ⌘"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przytrzymaj ⌘"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按住 ⌘"
          }
        }
      }
    },
    "Hold ⌘: release to pick. Stay open: pick with Return or the mouse.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "⌘ halten: zum Auswählen loslassen. Geöffnet lassen: mit Return oder der Maus auswählen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantener ⌘: suelta para seleccionar. Permanecer abierto: selecciona con Retorno o el ratón."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintenir ⌘ : relâchez pour sélectionner. Rester ouvert : sélectionnez avec Retour ou la souris."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przytrzymaj ⌘: puść, aby wybrać. Pozostaw otwarte: wybierz klawiszem Return lub myszą."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按住 ⌘：松开即选择。保持打开：用 Return 或鼠标选择。"
          }
        }
      }
    },
    "Hold the modifier (⌘ by default) and tap to move through your open apps.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Halte die Sondertaste (standardmäßig ⌘) gedrückt und tippe, um durch deine geöffneten Apps zu blättern."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén pulsado el modificador (⌘ de forma predeterminada) y toca para recorrer tus apps abiertas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintenez le modificateur (⌘ par défaut) et appuyez pour parcourir vos apps ouvertes."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przytrzymaj modyfikator (domyślnie ⌘) i stukaj, aby poruszać się po otwartych aplikacjach."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按住修饰键（默认 ⌘）并点按，在打开的应用间移动。"
          }
        }
      }
    },
    "Hover actions": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktionen beim Überfahren"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acciones al pasar el cursor"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Actions au survol"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Akcje po najechaniu"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "悬停操作"
          }
        }
      }
    },
    "How far to slide to move one app. Higher means a shorter slide steps further.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie weit du streichen musst, um eine App weiterzugehen. Höhere Werte bedeuten, dass ein kürzeres Streichen weiter springt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuánto hay que deslizar para avanzar una app. Cuanto más alto, un deslizamiento más corto avanza más."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Distance à parcourir pour avancer d’une app. Plus la valeur est élevée, plus un court glissement progresse loin."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jak daleko trzeba przesunąć, aby przejść o jedną aplikację. Wyższa wartość oznacza, że krótsze przesunięcie przenosi dalej."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "滑动多远移动一个应用。数值越高，较短滑动也会移动更远。"
          }
        }
      }
    },
    "How long a typed letter sequence stays active. When it expires, the highlight clears and the list returns to its original order.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie lange eine getippte Buchstabenfolge aktiv bleibt. Nach Ablauf wird die Hervorhebung entfernt und die Liste kehrt zur ursprünglichen Reihenfolge zurück."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuánto tiempo permanece activa una secuencia de letras escrita. Al expirar, se borra el resaltado y la lista vuelve a su orden original."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Durée pendant laquelle une séquence de lettres saisie reste active. À son expiration, la surbrillance disparaît et la liste retrouve son ordre d’origine."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jak długo wpisana sekwencja liter pozostaje aktywna. Po wygaśnięciu wyróżnienie znika, a lista wraca do pierwotnej kolejności."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "输入的字母序列保持有效的时间。过期后高亮清除，列表恢复原始顺序。"
          }
        }
      }
    },
    "How many recently closed items to list.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie viele zuletzt geschlossene Einträge aufgelistet werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuántos elementos cerrados recientemente se enumeran."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nombre d’éléments récemment fermés à lister."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ile ostatnio zamkniętych elementów wyświetlać."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示多少个最近关闭项。"
          }
        }
      }
    },
    "How often to check automatically. The beta channel always checks hourly.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie oft automatisch gesucht wird. Der Beta-Kanal sucht immer stündlich."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Con qué frecuencia buscar automáticamente. El canal beta siempre comprueba cada hora."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fréquence de vérification automatique. Le canal bêta vérifie toujours toutes les heures."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jak często sprawdzać automatycznie. Kanał beta zawsze sprawdza co godzinę."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动检查更新的频率。Beta 通道始终每小时检查一次。"
          }
        }
      }
    },
