    "Bring every hidden app back.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle ausgeblendeten Apps zurückholen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recupera todas las apps ocultas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rétablir toutes les apps masquées."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przywróć wszystkie ukryte aplikacje."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "恢复所有隐藏的应用。"
          }
        }
      }
    },
    "Browser tab access": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Browser-Tab-Zugriff"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acceso a las pestañas del navegador"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accès aux onglets du navigateur"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dostęp do kart przeglądarki"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "浏览器标签页访问权限"
          }
        }
      }
    },
    "Browsers need Apple Events consent to list their tabs. Click to prompt for each running browser (Safari, Chrome, Arc, Brave, Edge…). Must be done with this window open.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Browser benötigen die Apple-Events-Zustimmung, um ihre Tabs aufzulisten. Klicke, um jeden laufenden Browser (Safari, Chrome, Arc, Brave, Edge…) abzufragen. Muss bei geöffnetem Fenster erfolgen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los navegadores necesitan el consentimiento de Apple Events para listar sus pestañas. Haz clic para solicitarlo a cada navegador en ejecución (Safari, Chrome, Arc, Brave, Edge…). Debe hacerse con esta ventana abierta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les navigateurs ont besoin du consentement Apple Events pour lister leurs onglets. Cliquez pour le demander à chaque navigateur en cours d’exécution (Safari, Chrome, Arc, Brave, Edge…). À faire avec cette fenêtre ouverte."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przeglądarki potrzebują zgody Apple Events, aby wyświetlić listę swoich kart. Kliknij, aby poprosić o nią każdą uruchomioną przeglądarkę (Safari, Chrome, Arc, Brave, Edge…). Trzeba to zrobić przy otwartym tym oknie."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "浏览器需要 Apple Events 授权才能列出标签页。点击后会为每个正在运行的浏览器请求权限（Safari、Chrome、Arc、Brave、Edge 等）。请保持此窗口打开。"
          }
        }
      }
    },
