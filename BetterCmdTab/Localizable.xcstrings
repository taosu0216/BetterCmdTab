    "Selected apps are forced to the front of the switcher, before recents.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ausgewählte Apps werden im Umschalter ganz nach vorn gesetzt, vor den zuletzt verwendeten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las apps seleccionadas se sitúan al principio del selector, antes de las recientes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les apps sélectionnées sont placées en tête du sélecteur, avant les récentes."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybrane aplikacje są wymuszane na początek przełącznika, przed ostatnio używanymi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选中的应用会固定在切换器前面，排在最近使用项之前。"
          }
        }
      }
    },
    "Sends SIGKILL — for hung apps that ignore Quit. ⌘+⌥+Q always works regardless.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sendet SIGKILL — für hängende Apps, die „Beenden“ ignorieren. ⌘+⌥+Q funktioniert ungeachtet dessen immer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía SIGKILL: para apps colgadas que ignoran «Salir». ⌘+⌥+Q siempre funciona de todos modos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoie SIGKILL — pour les apps bloquées qui ignorent Quitter. ⌘+⌥+Q fonctionne toujours, quoi qu’il arrive."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wysyła SIGKILL — dla zawieszonych aplikacji, które ignorują polecenie Zakończ. ⌘+⌥+Q zawsze działa niezależnie od tego."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发送 SIGKILL — 用于无响应且忽略退出的应用。无论此选项如何，⌘+⌥+Q 始终可用。"
          }
        }
      }
    },
