    "Scroll up to move forward instead of down.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nach oben scrollen, um vorwärtszugehen, statt nach unten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desplázate hacia arriba para avanzar en lugar de hacia abajo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Défiler vers le haut pour avancer au lieu de vers le bas."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przewijaj w górę, aby przejść do przodu, zamiast w dół."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "向上滚动时前进，而不是向下滚动前进。"
          }
        }
      }
    },
    "Scroll up/down on a mouse wheel to move the selection while the switcher is open. Trackpads use the three-finger swipe instead.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Scrolle mit dem Mausrad nach oben/unten, um die Auswahl bei geöffnetem Umschalter zu verschieben. Trackpads verwenden stattdessen das Streichen mit drei Fingern."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desplázate hacia arriba o abajo con la rueda del ratón para mover la selección mientras el selector está abierto. Los trackpads usan el deslizamiento con tres dedos en su lugar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Faites défiler vers le haut/bas avec la molette de la souris pour déplacer la sélection lorsque le sélecteur est ouvert. Les trackpads utilisent plutôt le balayage à trois doigts."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przewijaj w górę/w dół kółkiem myszy, aby przesuwać zaznaczenie, gdy przełącznik jest otwarty. Gładziki używają zamiast tego przesunięcia trzema palcami."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "切换器打开时，用鼠标滚轮上下滚动移动选择。触控板请使用三指滑动。"
          }
        }
      }
    },
