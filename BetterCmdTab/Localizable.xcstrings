          "stringUnit": {
            "state": "translated",
            "value": "将浏览器标签页显示为单独条目"
          }
        }
      }
    },
    "Show each app's Dock badge count (e.g. Mail's unread mail) on its row.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeigt die Anzahl im Dock-Kennzeichen jeder App (z. B. ungelesene E-Mails in „Mail“) in ihrer Zeile an."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra en su fila el recuento del distintivo del Dock de cada app (por ejemplo, el correo no leído de Mail)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affiche le nombre de la pastille du Dock de chaque app (par ex. les messages non lus de Mail) sur sa ligne."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokazuj liczbę z plakietki w Docku każdej aplikacji (np. nieprzeczytane wiadomości w Mail) w jej wierszu."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在每行显示应用的 Dock 角标数量（例如邮件未读数）。"
          }
        }
      }
    },
    "Show each window's title under the icon in the Grid and Previews layouts.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeigt den Titel jedes Fensters unter dem Symbol in den Layouts „Raster“ und „Vorschauen“ an."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra el título de cada ventana bajo el icono en las disposiciones Cuadrícula y Vistas previas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affiche le titre de chaque fenêtre sous l’icône dans les dispositions Grille et Aperçus."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokazuj tytuł każdego okna pod ikoną w układach Siatka i Podglądy."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在网格和预览布局中，在图标下显示每个窗口标题。"
          }
