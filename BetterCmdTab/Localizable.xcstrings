    "Click anywhere outside the switcher to close it, leaving the current window focused.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Klicke irgendwo außerhalb des Umschalters, um ihn zu schließen, wobei das aktuelle Fenster aktiv bleibt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz clic en cualquier punto fuera del selector para cerrarlo, dejando enfocada la ventana actual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliquez n’importe où à l’extérieur du sélecteur pour le fermer, en laissant la fenêtre actuelle active."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kliknij w dowolnym miejscu poza przełącznikiem, aby go zamknąć, pozostawiając aktywne bieżące okno."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击切换器外任意位置即可关闭，并保持当前窗口聚焦。"
          }
        }
      }
    },
