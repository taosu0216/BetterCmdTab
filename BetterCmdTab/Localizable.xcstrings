    "Press / in the switcher to filter by app or window name.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drücke / im Umschalter, um nach App- oder Fensternamen zu filtern."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulsa / en el selector para filtrar por nombre de app o de ventana."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez sur / dans le sélecteur pour filtrer par nom d’app ou de fenêtre."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Naciśnij / w przełączniku, aby filtrować według nazwy aplikacji lub okna."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在切换器中按 / 可按应用或窗口名称过滤。"
          }
        }
      }
    },
    "Press \\ on a window that has tabs to reveal a strip below the switcher and pick a tab. Native tabs use Accessibility; browsers use Apple Events.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drücke \\ bei einem Fenster mit Tabs, um eine Leiste unter dem Umschalter einzublenden und einen Tab auszuwählen. Native Tabs nutzen die Bedienungshilfen, Browser nutzen Apple Events."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulsa \\ en una ventana con pestañas para mostrar una franja bajo el selector y elegir una pestaña. Las pestañas nativas usan Accesibilidad; los navegadores usan Apple Events."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez sur \\ sur une fenêtre comportant des onglets pour afficher une bande sous le sélecteur et choisir un onglet. Les onglets natifs utilisent l’Accessibilité ; les navigateurs utilisent Apple Events."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Naciśnij \\ na oknie z kartami, aby wyświetlić pasek pod przełącznikiem i wybrać kartę. Natywne karty używają Dostępności, a przeglądarki — Apple Events."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在带标签页的窗口上按 \\，会在切换器下方显示标签页条并选择标签页。原生标签页使用辅助功能；浏览器使用 Apple Events。"
          }
        }
      }
    },
    "Press Tile left / Tile right again to step the window through ½ → ⅔ → ⅓ of the screen on that side.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drücke „Linke Hälfte“ / „Rechte Hälfte“ erneut, um das Fenster auf dieser Seite durch ½ → ⅔ → ⅓ des Bildschirms zu schalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulsa de nuevo «Mitad izquierda» / «Mitad derecha» para recorrer la ventana por ½ → ⅔ → ⅓ de la pantalla en ese lado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez de nouveau sur Moitié gauche / Moitié droite pour faire passer la fenêtre par ½ → ⅔ → ⅓ de l’écran de ce côté."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Naciśnij ponownie Lewa połowa / Prawa połowa, aby przesuwać okno przez ½ → ⅔ → ⅓ ekranu po tej stronie."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "再次按“平铺到左侧/右侧”时，窗口会在该侧按 ½ → ⅔ → ⅓ 屏宽循环。"
          }
        }
      }
    },
