    "Browser tab drill-in" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Browser-Tabs aufschlüsseln"
          }
        },
        "es" : {
          "stringUnit" : {
