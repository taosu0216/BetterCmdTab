<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Partial Info.plist. GENERATE_INFOPLIST_FILE is still YES, so Xcode merges
	  the build-setting-derived keys (INFOPLIST_KEY_*) on top of this file. Only
	  declare here what those settings can't express — the exported UTI and
	  document-type association for the .cmdtab settings export.
	-->
	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>pro.bettercmdtab.settings</string>
			<key>UTTypeDescription</key>
			<string>BetterCmdTab Settings</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.json</string>
				<string>public.data</string>
			</array>
			<key>UTTypeIconFile</key>
			<string>CmdTabDocument</string>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>cmdtab</string>
				</array>
				<key>public.mime-type</key>
				<array>
					<string>application/vnd.bettercmdtab.settings+json</string>
				</array>
			</dict>
		</dict>
	</array>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>BetterCmdTab Settings</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>CFBundleTypeIconFile</key>
			<string>CmdTabDocument</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>pro.bettercmdtab.settings</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
